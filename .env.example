# Copy to `.env` in the project root. Never commit real secrets.
#
# If your key contains `#` or spaces, use double quotes or the value may be truncated:
# OPENAI_API_KEY="sk-..."
OPENAI_API_KEY=

# Optional: embedding-3-small (default) | pseudo (offline deterministic)
EMBEDDING_MODE=embedding-3-small

# Optional overrides
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LOG_LEVEL=INFO
